const CONFIG_KEYS = {
  API_KEY:            'ANTHROPIC_API_KEY',    // secret; never hardcode a value
  MODEL:              'ANTHROPIC_MODEL',      // e.g. a current Claude model id
  SOURCE_TAB:         'SOURCE_TAB_NAME',      // tab name inside the uploaded export
  MASTER_SHEET:       'MASTER_SHEET_NAME',    // where imported rows are appended
  SUMMARY_SHEET:      'SUMMARY_SHEET_NAME',   // your pivot/summary sheet
  INSIGHTS_SHEET:     'INSIGHTS_SHEET_NAME',  // where AI insights are written
  DEFAULT_SOURCE_URL: 'DEFAULT_SOURCE_URL',   // optional; blank by default (no real IDs)
};

// Sensible defaults so the template runs before the user customizes anything.
const CONFIG_DEFAULTS = {
  ANTHROPIC_MODEL:      'claude-sonnet-4-5',  // set to your preferred model in Setup
  SOURCE_TAB_NAME:      'Worksheet',
  MASTER_SHEET_NAME:    'master',
  SUMMARY_SHEET_NAME:   'Summary',
  INSIGHTS_SHEET_NAME:  'AI Insights',
  DEFAULT_SOURCE_URL:   '',
};

/** Reads all config from Script Properties, falling back to defaults. */
function getConfig_() {
  const props = PropertiesService.getScriptProperties();
  const cfg = {};
  for (const key of Object.values(CONFIG_KEYS)) {
    cfg[key] = props.getProperty(key) || CONFIG_DEFAULTS[key] || '';
  }
  return cfg;
}

/** Writes a single config value to Script Properties. */
function saveConfig_(key, value) {
  PropertiesService.getScriptProperties().setProperty(key, String(value).trim());
}


