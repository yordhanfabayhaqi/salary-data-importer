// Generic analyst prompt. No company, country, or sector specifics. Customize
// the domain context for your own organization if you want sharper output.
const SYSTEM_PROMPT =
  'You are a senior compensation & payroll analyst advising a company leadership team. ' +
  'All currency figures are provided as-is. Before flagging any month-over-month change as an ' +
  'anomaly, decompose it into its components (base pay, allowances, one-time bonuses, tax ' +
  'withholding, statutory contributions, severance, headcount change). Many swings are explained ' +
  'by seasonal bonuses, annual tax true-ups, statutory-ceiling adjustments, or joiners/leavers — ' +
  'check those first. Only flag a genuine anomaly when the components do not explain the delta. ' +
  'Compare like-for-like by stripping out one-time items to see the normalized trend. ' +
  'Be direct, data-driven, and actionable.';

function getClaudeInsights(customPrompt) {
  const cfg = getConfig_();
  const apiKey = cfg[CONFIG_KEYS.API_KEY];
  if (!apiKey) return { error: 'No API key. Use ⚙️ Setup → Set Anthropic API Key.' };

  const summary = buildSummary_(getDashboardData(), getComponentData_());
  const userMsg = (customPrompt || 'Give me 5 key insights for this month. Decompose any pay changes into components before concluding.') + '\n\n' + summary;

  try {
    const response = UrlFetchApp.fetch('https://api.anthropic.com/v1/messages', {
      method: 'post',
      headers: { 'Content-Type': 'application/json', 'x-api-key': apiKey, 'anthropic-version': '2023-06-01' },
      payload: JSON.stringify({
        model: cfg[CONFIG_KEYS.MODEL],
        max_tokens: 3000,
        system: SYSTEM_PROMPT,
        messages: [{ role: 'user', content: userMsg }],
      }),
      muteHttpExceptions: true,
    });
    const result = JSON.parse(response.getContentText());
    return result.error ? { error: result.error.message } : { insights: result.content[0].text };
  } catch (e) {
    return { error: e.toString() };
  }
}

/** Aggregate the (synthetic) components per month from the master sheet. */
function getComponentData_() {
  const cfg = getConfig_();
  const master = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(cfg[CONFIG_KEYS.MASTER_SHEET]);
  const all = master.getDataRange().getValues();
  const headers = all[0];
  const col = {};
  ['Month', 'Group Lead', 'Group', 'Base Pay', 'Allowances', 'Bonus', 'Tax Withheld', 'Deductions', 'Net Pay', 'Employer Cost']
    .forEach(f => { col[f] = headers.indexOf(f); });

  const byMonth = {};
  for (let r = 1; r < all.length; r++) {
    const mv = all[r][col['Month']];
    if (!mv) continue;
    if (all[r][col['Group Lead']] === '-') continue; // included population only
    const d = mv instanceof Date ? mv : new Date(mv);
    const key = monthName_(d.getMonth()) + ' ' + d.getFullYear();
    if (!byMonth[key]) byMonth[key] = { headcount: 0, basePay: 0, allowances: 0, bonus: 0, taxWithheld: 0, deductions: 0, netPay: 0, employerCost: 0 };
    const m = byMonth[key];
    m.headcount++;
    m.basePay      += Number(all[r][col['Base Pay']])      || 0;
    m.allowances   += Number(all[r][col['Allowances']])    || 0;
    m.bonus        += Number(all[r][col['Bonus']])         || 0;
    m.taxWithheld  += Number(all[r][col['Tax Withheld']])  || 0;
    m.deductions   += Number(all[r][col['Deductions']])    || 0;
    m.netPay       += Number(all[r][col['Net Pay']])       || 0;
    m.employerCost += Number(all[r][col['Employer Cost']]) || 0;
  }
  return byMonth;
}

function buildSummary_(data, components) {
  const f = v => v ? 'Rp ' + (v / 1e6).toFixed(1) + 'M' : '-';
  const lines = ['=== NET PAY GRAND TOTALS (from Summary) ==='];
  data.months.forEach((m, i) => lines.push(m + ': ' + f(data.grandTotals[i])));

  lines.push('\n=== COMPONENT BREAKDOWN (per month, included population) ===');
  const order = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const keys = Object.keys(components).sort((a, b) => {
    const [am, ay] = a.split(' '), [bm, by] = b.split(' ');
    return (Number(ay) * 12 + order.indexOf(am)) - (Number(by) * 12 + order.indexOf(bm));
  });
  keys.slice(-6).forEach(key => {
    const m = components[key];
    lines.push('\n--- ' + key + ' (' + m.headcount + ' people) ---');
    lines.push('  Base Pay:      ' + f(m.basePay));
    lines.push('  Allowances:    ' + f(m.allowances));
    lines.push('  Bonus:         ' + f(m.bonus));
    lines.push('  Tax Withheld:  ' + f(m.taxWithheld));
    lines.push('  Deductions:    ' + f(m.deductions));
    lines.push('  >>> Net Pay:   ' + f(m.netPay));
    lines.push('  >>> Employer Cost: ' + f(m.employerCost));
  });

  if (keys.length >= 2) {
    const curr = components[keys[keys.length - 1]], prev = components[keys[keys.length - 2]];
    lines.push('\n=== MONTH-OVER-MONTH DELTA: ' + keys[keys.length - 2] + ' → ' + keys[keys.length - 1] + ' ===');
    lines.push('  Headcount:    ' + prev.headcount + ' → ' + curr.headcount + ' (' + (curr.headcount - prev.headcount >= 0 ? '+' : '') + (curr.headcount - prev.headcount) + ')');
    lines.push('  Base Pay:     ' + f(curr.basePay - prev.basePay) + ' change');
    lines.push('  Bonus:        ' + f(curr.bonus - prev.bonus) + ' change');
    lines.push('  Tax Withheld: ' + f(curr.taxWithheld - prev.taxWithheld) + ' change');
    lines.push('  Net Pay:      ' + f(curr.netPay - prev.netPay) + ' change');
    lines.push('  Employer Cost:' + f(curr.employerCost - prev.employerCost) + ' change');
  }

  lines.push('\n=== FINANCE (from Summary) ===');
  data.months.forEach((m, i) => {
    const rev = data.finance.revenue[i];
    if (rev) lines.push(m + ': Rev=' + f(rev) + ', Rev/Sal=' + (data.revPerSalary[i] ? data.revPerSalary[i].toFixed(2) : 'N/A') + 'x');
  });
  return lines.join('\n');
}

function generateInsights() {
  const ui = SpreadsheetApp.getUi();
  const cfg = getConfig_();
  const result = getClaudeInsights();
  if (result.error) { ui.alert('Error', result.error, ui.ButtonSet.OK); return; }
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName(cfg[CONFIG_KEYS.INSIGHTS_SHEET]);
  if (!sheet) sheet = ss.insertSheet(cfg[CONFIG_KEYS.INSIGHTS_SHEET]);
  sheet.clear();
  sheet.getRange('A1').setValue('AI-Generated Insights').setFontWeight('bold').setFontSize(14);
  sheet.getRange('A2').setValue('Generated: ' + new Date().toLocaleString()).setFontColor('#666');
  sheet.getRange('A4').setValue(result.insights).setWrap(true);
  sheet.setColumnWidth(1, 800);
  ui.alert('Done', 'Insights written to "' + cfg[CONFIG_KEYS.INSIGHTS_SHEET] + '".', ui.ButtonSet.OK);
}

function getInsightsForDashboard(question) {
  return getClaudeInsights(question);
