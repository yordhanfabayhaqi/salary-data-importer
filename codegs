// ─── CORE IMPORT ENGINE (writes to the master sheet ONLY) ────────────────────

/**
 * Import a month of data from a source spreadsheet URL.
 * @param {string} sourceUrl - source spreadsheet URL (or ID)
 * @param {number} year
 * @param {number} month - 1-12
 * @return {object} { success, message, stats }
 */
function importPayrollFromUrl(sourceUrl, year, month) {
  try {
    const cfg = getConfig_();
    const url = sourceUrl || cfg[CONFIG_KEYS.DEFAULT_SOURCE_URL];
    if (!url) throw new Error('No source URL provided and no default configured.');

    const source = SpreadsheetApp.openById(extractSheetId_(url));
    const tab = source.getSheetByName(cfg[CONFIG_KEYS.SOURCE_TAB]);
    if (!tab) throw new Error('Tab "' + cfg[CONFIG_KEYS.SOURCE_TAB] + '" not found in source.');

    const rawData = tab.getDataRange().getValues();
    return processImport_(rawData, year, month, cfg);
  } catch (e) {
    return { success: false, message: 'Error: ' + e.toString() };
  }
}

/** Import from an in-memory 2D array (e.g. parsed CSV). */
function importPayrollFromData(data, year, month) {
  try {
    return processImport_(data, year, month, getConfig_());
  } catch (e) {
    return { success: false, message: 'Error: ' + e.toString() };
  }
}

/** Shared import pipeline. */
function processImport_(rawData, year, month, cfg) {
  const monthDate = new Date(year, month - 1, 1);
  const monthLabel = monthName_(month - 1) + ' ' + year;

  // Map source columns → master fields using the header row.
  const subHeaders = (rawData[SCHEMA.HEADER_ROW_INDEX] || []).map(v => v ? String(v).trim() : '');
  const colIdx = {};
  subHeaders.forEach((h, i) => {
    if (h && SCHEMA.IMPORT_FIELD_MAP[h]) colIdx[SCHEMA.IMPORT_FIELD_MAP[h]] = i;
  });
  if (colIdx['Employee ID'] === undefined) {
    throw new Error('Could not find an "Employee ID" column on header row ' + SCHEMA.HEADER_ROW_INDEX + '. Adjust SCHEMA for your export.');
  }

  const skip = new Set(SCHEMA.SKIP_IDS);
  const employees = [];
  for (let r = SCHEMA.FIRST_DATA_ROW; r < rawData.length; r++) {
    const eid = rawData[r][colIdx['Employee ID']];
    if (!eid || skip.has(String(eid).trim())) continue;
    const emp = {};
    for (const [field, idx] of Object.entries(colIdx)) emp[field] = rawData[r][idx];
    employees.push(emp);
  }
  if (employees.length === 0) throw new Error('No data rows found. Check SCHEMA.FIRST_DATA_ROW / header mapping.');

  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const master = ss.getSheetByName(cfg[CONFIG_KEYS.MASTER_SHEET]);
  if (!master) throw new Error('Master sheet "' + cfg[CONFIG_KEYS.MASTER_SHEET] + '" not found.');

  const dlMap = buildLeadMap_(master.getDataRange().getValues());
  const processed = employees.map(emp => assignGroup_(emp, dlMap));
  const included = processed.filter(e => !e._excluded);

  appendToMaster_(master, processed, monthDate);

  const stats = {
    totalEmployees:    processed.length,
    includedEmployees: included.length,
    excludedEmployees: processed.length - included.length,
    totalNetPay:       included.reduce((s, e) => s + (Number(e['Net Pay']) || 0), 0),
    byLead: {},
    byGroup: {},
  };
  included.forEach(e => {
    const lead = e['Group Lead'] || '-';
    const grp = e['Group'] || '-';
    stats.byLead[lead]  = (stats.byLead[lead]  || 0) + (Number(e['Net Pay']) || 0);
    stats.byGroup[grp]  = (stats.byGroup[grp]  || 0) + (Number(e['Net Pay']) || 0);
  });

  return {
    success: true,
    message: 'Imported ' + monthLabel + ' to master sheet (' + processed.length + ' rows). Refresh pivots/summaries.',
    stats,
  };
}


// ─── ASSIGNMENT LOGIC ────────────────────────────────────────────────────────

function buildLeadMap_(masterData) {
  const map = {};
  const headers = masterData[0] || [];
  const eidCol  = headers.indexOf('Employee ID');
  const leadCol = headers.indexOf('Group Lead');
  const grpCol  = headers.indexOf('Group');
  if (eidCol === -1) return map;

  for (let r = 1; r < masterData.length; r++) {
    const eid  = masterData[r][eidCol];
    const lead = masterData[r][leadCol];
    const grp  = masterData[r][grpCol];
    if (!eid) continue;
    if (!map[eid]) map[eid] = { lead: '-', group: '-', wasDash: false };
    if (lead === '-' || !lead) map[eid].wasDash = true;
    if (lead && lead !== '-') { map[eid].lead = lead; map[eid].group = grp || '-'; }
  }
  return map;
}

function assignGroup_(emp, dlMap) {
  const eid  = String(emp['Employee ID'] || '').trim();
  const dept = String(emp['Department'] || '').trim();
  const loc  = String(emp['Location'] || '').trim();
  const role = String(emp['Role'] || '').trim();

  let excluded = false;

  // Rule 1: unit-level roles.
  if (RULES.EXCLUDED_ROLES.some(p => role.includes(p))) excluded = true;

  // Rule 2: field department outside HQ.
  if (dept === RULES.FIELD_DEPARTMENT && !RULES.HQ_LOCATIONS.includes(loc)) excluded = true;

  // Rule 3: field-only role outside HQ.
  if (role.includes(RULES.FIELD_ROLE) && !RULES.HQ_LOCATIONS.includes(loc)) excluded = true;

  // Rule 4: historically unassigned AND still field department outside HQ.
  if (dlMap[eid] && dlMap[eid].wasDash && !RULES.HQ_LOCATIONS.includes(loc) && dept === RULES.FIELD_DEPARTMENT) {
    excluded = true;
  }

  if (excluded) {
    emp['Group Lead'] = '-';
    emp['Group'] = '-';
    emp._excluded = true;
    return emp;
  }

  if (dlMap[eid] && dlMap[eid].lead !== '-') {
    emp['Group Lead'] = dlMap[eid].lead;
    emp['Group'] = dlMap[eid].group;
  } else {
    const group = RULES.DEPT_TO_GROUP[dept] || '-';
    emp['Group'] = group;
    emp['Group Lead'] = RULES.GROUP_TO_LEAD[group] || '-';
  }

  emp._excluded = false;
  return emp;
}


// ─── MASTER SHEET WRITER ─────────────────────────────────────────────────────

function appendToMaster_(sheet, employees, monthDate) {
  const fieldToCol = {};
  for (const [col, field] of Object.entries(SCHEMA.MASTER_COLUMNS)) fieldToCol[field] = Number(col);
  const numCols = Math.max(...Object.keys(SCHEMA.MASTER_COLUMNS).map(Number));

  const rows = employees.map(emp => {
    const row = new Array(numCols).fill('');
    for (const [field, col] of Object.entries(fieldToCol)) {
      let val = (field === 'Month') ? monthDate : emp[field];
      if (val !== undefined && val !== null && val !== '') row[col - 1] = val;
    }
    return row;
  });
  if (rows.length === 0) return;

  // Batch writes + retry: large single writes to sheets with many dependent
  // formulas can trigger transient backend errors. Small committed batches avoid it.
  const BATCH_SIZE = 15;
  const MAX_RETRIES = 3;

  for (let i = 0; i < rows.length; i += BATCH_SIZE) {
    const chunk = rows.slice(i, i + BATCH_SIZE);
    const startRow = sheet.getLastRow() + 1;
    let ok = false;
    for (let attempt = 1; attempt <= MAX_RETRIES; attempt++) {
      try {
        sheet.getRange(startRow, 1, chunk.length, numCols).setValues(chunk);
        SpreadsheetApp.flush();
        ok = true;
        break;
      } catch (e) {
        if (attempt < MAX_RETRIES) {
          Utilities.sleep(2000 * attempt);
        } else {
          throw new Error('Failed to write rows ' + (i + 1) + '-' + (i + chunk.length) +
            ' after ' + MAX_RETRIES + ' attempts. Rows 1-' + i + ' were written. ' + e.toString());
        }
      }
    }
    if (!ok) break;
  }
}


// ─── UTILITY ─────────────────────────────────────────────────────────────────

function extractSheetId_(url) {
  const match = url.match(/\/spreadsheets\/d\/([a-zA-Z0-9_-]+)/);
  if (match) return match[1];
  if (/^[a-zA-Z0-9_-]+$/.test(url)) return url;
  throw new Error('Could not extract spreadsheet ID from: ' + url);
}

function monthName_(idx) {
  return ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'][idx];
}

function getAvailableMonths() {
  const cfg = getConfig_();
  const master = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(cfg[CONFIG_KEYS.MASTER_SHEET]);
  if (!master || master.getLastRow() < 2) return [];
  const data = master.getRange(2, 1, master.getLastRow() - 1, 1).getValues();
  const seen = new Set();
  const months = [];
  data.forEach(r => {
    if (!r[0]) return;
    const d = new Date(r[0]);
    const label = monthName_(d.getMonth()) + ' ' + d.getFullYear();
    if (!seen.has(label)) { seen.add(label); months.push(label); }
  });
  return months;
}


// ─── DASHBOARD DATA (reads from your Summary sheet) ──────────────────────────
// The row/column offsets below map to a SPECIFIC summary-sheet layout and are
// EXAMPLE VALUES. Adjust SUMMARY_LAYOUT to match your own pivot/summary sheet.

const SUMMARY_LAYOUT = {
  READ_ROWS: 55,          // how many rows to read
  READ_COLS: 32,          // how many cols to read
  HEADER_ROW: 2,          // 0-based row holding period headers
  FIRST_VALUE_COL: 2,     // 0-based first column holding numbers
  LEAD_ROWS: [4, 5, 6, 7, 8],    // rows: Net Pay by Group Lead
  GRAND_TOTAL_ROW: 9,            // row: Net Pay grand total
  GROUP_ROWS: [20, 21, 22, 23, 24], // rows: Net Pay by Group
  REVENUE_ROW: 15,        // row: revenue (or any headline metric)
  METRIC_A_ROW: 16,
  METRIC_B_ROW: 17,
  EMPLOYER_COST_TOTAL_ROW: 50,
  EMPLOYER_COST_GROUP_ROWS: [45, 46, 47, 48, 49],
  // Generic placeholder labels — replace to match your summary sheet rows.
  LEAD_NAMES:  ['Group Lead A', 'Group Lead B', 'Group Lead C', 'Group Lead D', 'Group Lead E'],
  GROUP_NAMES: ['Corporate', 'Growth', 'Technology', 'Operations', 'Other'],
};

function getDashboardData() {
  const cfg = getConfig_();
  const summary = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(cfg[CONFIG_KEYS.SUMMARY_SHEET]);
  if (!summary) throw new Error('Summary sheet "' + cfg[CONFIG_KEYS.SUMMARY_SHEET] + '" not found.');

  const L = SUMMARY_LAYOUT;
  const sa = summary.getRange(1, 1, L.READ_ROWS, L.READ_COLS).getValues();

  const headers = [];
  for (let c = L.FIRST_VALUE_COL; c < L.READ_COLS; c++) {
    const v = sa[L.HEADER_ROW][c];
    if (!v) break;
    headers.push(String(v).replace(' Total', ''));
  }
  const n = headers.length;
  const slice = rowIdx => sa[rowIdx].slice(L.FIRST_VALUE_COL, L.FIRST_VALUE_COL + n).map(v => v || 0);

  const netByLead = {};
  L.LEAD_ROWS.forEach((ri, i) => { netByLead[L.LEAD_NAMES[i]] = slice(ri); });

  const grandTotals = slice(L.GRAND_TOTAL_ROW);

  const netByGroup = {};
  L.GROUP_ROWS.forEach((ri, i) => { netByGroup[L.GROUP_NAMES[i]] = slice(ri); });

  const finance = {
    revenue:  sa[L.REVENUE_ROW].slice(L.FIRST_VALUE_COL, L.FIRST_VALUE_COL + n).map(v => v || null),
    metricA:  sa[L.METRIC_A_ROW].slice(L.FIRST_VALUE_COL, L.FIRST_VALUE_COL + n).map(v => v || null),
    metricB:  sa[L.METRIC_B_ROW].slice(L.FIRST_VALUE_COL, L.FIRST_VALUE_COL + n).map(v => v || null),
  };

  const employerCostTotal = slice(L.EMPLOYER_COST_TOTAL_ROW);
  const employerCostByGroup = {};
  L.EMPLOYER_COST_GROUP_ROWS.forEach((ri, i) => { employerCostByGroup[L.GROUP_NAMES[i]] = slice(ri); });

  const revPerSalary = headers.map((_, i) => {
    const rev = finance.revenue[i], net = grandTotals[i];
    return (rev && net) ? rev / net : null;
  });

  return { months: headers, netByLead, netByGroup, grandTotals, employerCostByGroup, employerCostTotal, finance, headcounts: {}, revPerSalary };
}

/** Headcount per month from the master sheet (called after initial render). */
function getHeadcountData() {
  const cfg = getConfig_();
  const master = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(cfg[CONFIG_KEYS.MASTER_SHEET]);
  if (!master || master.getLastRow() <= 1) return { total: {} };

  const idCol = master.getDataRange().getValues()[0].indexOf('Employee ID');
  const data = master.getRange(2, 1, master.getLastRow() - 1, master.getLastColumn()).getValues();
  const counts = {};
  data.forEach(row => {
    const mv = row[0];
    if (!mv) return;
    const d = mv instanceof Date ? mv : new Date(mv);
    const key = d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0');
    if (!counts[key]) counts[key] = new Set();
    counts[key].add(row[idCol]);
  });
  const out = {};
  for (const [k, v] of Object.entries(counts)) out[k] = v.size;
  return { total: out };
}

/**
 * Example one-time-component breakdown (the "Bonus" toggle on the dashboard).
 * Demonstration logic only: sums the Bonus component per month by Group.
 * If some one-time payouts are disbursed off-cycle in your real data, add your
 * own reconciliation before trusting this figure.
 */
function getBonusBreakdown() {
  const cfg = getConfig_();
  const master = SpreadsheetApp.getActiveSpreadsheet().getSheetByName(cfg[CONFIG_KEYS.MASTER_SHEET]);
  if (!master || master.getLastRow() <= 1) return {};

  const headers = master.getRange(1, 1, 1, master.getLastColumn()).getValues()[0];
  const col = {};
  ['Month', 'Group Lead', 'Group', 'Bonus'].forEach(f => { col[f] = headers.indexOf(f); });

  const data = master.getRange(2, 1, master.getLastRow() - 1, master.getLastColumn()).getValues();
  const byMonth = {};
  for (let r = 0; r < data.length; r++) {
    const mv = data[r][col['Month']];
    if (!mv) continue;
    if (data[r][col['Group Lead']] === '-') continue;
    const bonus = Number(data[r][col['Bonus']]) || 0;
    if (bonus === 0) continue;

    const d = mv instanceof Date ? mv : new Date(mv);
    const key = monthName_(d.getMonth()) + ' ' + d.getFullYear();
    if (!byMonth[key]) byMonth[key] = { total: 0, byLead: {}, byGroup: {} };
    byMonth[key].total += bonus;
    const lead = data[r][col['Group Lead']];
    const grp = data[r][col['Group']] || '-';
    byMonth[key].byLead[lead]  = (byMonth[key].byLead[lead]  || 0) + bonus;
    byMonth[key].byGroup[grp]  = (byMonth[key].byGroup[grp]  || 0) + bonus;
  }
  return byMonth;
}

/**
 * Benchmark scaffold for a "revenue per salary" style tab.
 * Values here are ILLUSTRATIVE PLACEHOLDERS, not real market data or real
